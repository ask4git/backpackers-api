# ===== 로컬 개발 환경 (.env.local) =====
# 이 파일을 복사해서 .env.local 을 만드세요
# ENVIRONMENT는 ENV_FILE 이름에서 자동 추론됩니다 (local)

# ===== 데이터베이스 (docker-compose) =====
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=curve

# ===== 보안 =====
# 생성: make secret-gen
SECRET_KEY=change-this-for-local-dev

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
