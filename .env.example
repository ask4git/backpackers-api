# ===== 환경 구분 =====
ENVIRONMENT=local   # local | devel | prod

# ===== 데이터베이스 =====
# 로컬 개발용 (docker-compose 사용 시)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=backpackers

# 프로덕션 (SSH 터널 연결 시)
# DB_HOST=localhost      ← 터널 연결 후 localhost로 접근
# DB_PORT=5432
# DB_USER=backpackers_user
# DB_PASSWORD=<실제 패스워드>
# DB_NAME=backpackers

# ===== 보안 =====
# 생성: make secret-gen
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# 프로덕션: GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ===== CORS =====
# 개발: localhost 포트들
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# 프로덕션: 실제 프론트엔드 도메인 (GitHub Secret으로 관리)
# CORS_ORIGINS=https://app.example.com,https://www.example.com
