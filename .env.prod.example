# ===== 프로덕션 환경 (.env.prod) =====
# 이 파일을 복사해서 .env.prod 를 만들고 실제 값을 채우세요
# ENVIRONMENT는 ENV_FILE 이름에서 자동 추론됩니다 (prod)

# ===== 데이터베이스 =====
# SSH 터널 연결 시: make tunnel → localhost:5432 → Lightsail Managed DB
DB_HOST=localhost
RDS_HOST=<RDS 엔드포인트>
BASTION_IP=<바스티온 서버 퍼블릭 IP>
DB_PORT=5432
DB_USER=backpackers_user
DB_PASSWORD=<실제 패스워드>
DB_NAME=backpackers

# ===== 보안 =====
# 생성: make secret-gen
SECRET_KEY=<openssl rand -hex 32 결과>

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=<실제값>

# ===== CORS =====
CORS_ORIGINS=https://<프론트엔드 도메인>
