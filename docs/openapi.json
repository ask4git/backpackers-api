{
  "openapi": "3.0.3",
  "info": {
    "title": "Backpackers API",
    "description": "국립공원·캠핑장 정보 플랫폼 API",
    "version": "0.1.0"
  },
  "servers": [
    { "url": "{{base_url}}", "description": "Lightsail (prod)" },
    { "url": "http://localhost:8000", "description": "Local" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserRegister": {
        "type": "object",
        "required": ["email", "password", "name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "UserLogin": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "GoogleVerifyRequest": {
        "type": "object",
        "required": ["id_token"],
        "properties": {
          "id_token": { "type": "string" }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "token_type": { "type": "string", "example": "bearer" },
          "user": { "$ref": "#/components/schemas/UserResponse" }
        }
      },
      "ReviewCreate": {
        "type": "object",
        "required": ["rating"],
        "properties": {
          "rating": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 5,
            "description": "별점 (0~5)"
          },
          "content": {
            "type": "string",
            "nullable": true,
            "description": "리뷰 내용"
          }
        }
      },
      "ReviewResponse": {
        "type": "object",
        "properties": {
          "uid": { "type": "string", "format": "uuid" },
          "spot_uid": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "rating": { "type": "number", "format": "float" },
          "content": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ReviewListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ReviewResponse" }
          },
          "total": { "type": "integer" },
          "rating_avg": { "type": "number", "format": "float" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "헬스 체크",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "서버 상태 정상",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "environment": { "type": "string", "example": "local" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "회원가입",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserRegister" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공 — JWT 토큰 반환",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": {
            "description": "이미 사용중인 이메일"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "이메일/패스워드 로그인",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserLogin" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공 — JWT 토큰 반환",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "401": {
            "description": "이메일 또는 비밀번호가 올바르지 않음"
          }
        }
      }
    },
    "/auth/google/verify": {
      "post": {
        "tags": ["auth"],
        "summary": "Google ID Token 검증 및 로그인",
        "description": "프론트엔드가 Google로부터 받은 ID Token을 서버에서 검증 후 JWT 발급. 신규 사용자면 자동 가입.",
        "operationId": "googleVerify",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GoogleVerifyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Google 인증 성공 — JWT 토큰 반환",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": {
            "description": "유효하지 않은 Google 토큰 또는 이메일 없음"
          }
        }
      }
    },
    "/spots/{spot_uid}/reviews": {
      "post": {
        "tags": ["reviews"],
        "summary": "리뷰 작성",
        "description": "스팟에 별점(0~5)과 리뷰를 작성. 유저당 스팟 1개 리뷰만 허용.",
        "operationId": "writeReview",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "spot_uid",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReviewCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "리뷰 작성 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReviewResponse" }
              }
            }
          },
          "401": {
            "description": "인증 필요"
          },
          "404": {
            "description": "존재하지 않는 스팟"
          },
          "409": {
            "description": "이미 이 스팟에 리뷰를 작성함"
          }
        }
      },
      "get": {
        "tags": ["reviews"],
        "summary": "리뷰 목록 조회",
        "description": "특정 스팟의 리뷰 목록과 평균 별점을 반환.",
        "operationId": "listReviews",
        "parameters": [
          {
            "name": "spot_uid",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "리뷰 목록 및 평균 별점",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReviewListResponse" }
              }
            }
          }
        }
      }
    }
  }
}
